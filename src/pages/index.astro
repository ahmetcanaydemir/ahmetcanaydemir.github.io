---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Bio from '../components/Bio.astro';
import { formatDate, readingTime } from '../utils/format';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://ahmetcan.org/#blog',
  name: 'Ahmet Can Aydemir',
  url: 'https://ahmetcan.org/',
  description: 'Personal blog by Ahmet Can Aydemir.',
  inLanguage: 'en',
  author: {
    '@type': 'Person',
    name: 'Ahmet Can Aydemir',
    url: 'https://ahmetcan.org/about/',
  },
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description ?? '',
    datePublished: post.data.date.toISOString(),
    url: `https://ahmetcan.org/${post.id}/`,
  })),
};
---

<BaseLayout jsonLd={blogJsonLd}>
  <Bio size="large" showText={false} />

  <section class="intro">
    <h1>Hey, I'm Ahmet Can!</h1>
    <p>
      Software engineer at Amazon, in London. I write here about things I figure out at
      work and want to remember.
    </p>
  </section>

  <ul class="post-list">
    {
      posts.map((post) => (
        <li class="post-list-item">
          <h2>
            <a href={`/${post.id}/`}>{post.data.title}</a>
          </h2>
          <span class="post-meta">
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
            {' • '}
            {readingTime(post.body ?? '')}
          </span>
          {post.data.description && <p class="post-spoiler">{post.data.description}</p>}
        </li>
      ))
    }
  </ul>
</BaseLayout>
